        ],
        "url": {
          "raw": "{{sql_base_url}}/sql/fhir/test/Patient?family=Smith&birthdate=1985-03-15&_format=json",
          "host": ["{{sql_base_url}}"],
          "path": ["sql", "fhir", "test", "Patient"],
          "query": [
            { "key": "family", "value": "Smith" },
            { "key": "birthdate", "value": "1985-03-15" },
            { "key": "_format", "value": "json" }
