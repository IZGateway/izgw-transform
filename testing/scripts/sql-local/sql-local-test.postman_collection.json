    },
    {
      "name": "LT_06 bulk export kickoff returns 202 with Content-Location",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 202 Accepted', function() {",
              "  pm.response.to.have.status(202);",
              "});",
              "",
              "pm.test('Content-Location header present', function() {",
              "  pm.expect(pm.response.headers.get('Content-Location')).to.not.be.empty;",
              "});",
              "",
              "var loc = pm.response.headers.get('Content-Location');",
              "if (loc) {",
              "  var jobId = loc.split('/').pop();",
              "  pm.collectionVariables.set('bulk_job_id', jobId);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Accept", "value": "application/fhir+json" },
          { "key": "Prefer", "value": "respond-async" },
          { "key": "Authorization", "value": "Bearer {{jwt_sender_token}}" }
        ],
        "url": {
          "raw": "{{sql_base_url}}/bulk/sql/fhir/$export",
          "host": ["{{sql_base_url}}"],
          "path": ["bulk", "sql", "fhir", "$export"]
        }
      }
    },
    {
