        ],
        "url": {
          "raw": "{{sql_base_url}}/bulk/sql/fhir/$export-status/{{bulk_job_id}}",
          "host": ["{{sql_base_url}}"],
          "path": ["bulk", "sql", "fhir", "$export-status", "{{bulk_job_id}}"]
        }
      }
    },
    {
